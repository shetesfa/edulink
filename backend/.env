APP_NAME="EduLink"
APP_ENV=production
APP_KEY=base64:ZhbzadnsVBX1uyzRLjMdjObQEP/GPayVLN8H/UX59iY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
APP_TIMEZONE=Africa/Addis_Ababa

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database ────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=edulink
DB_USERNAME=root
DB_PASSWORD=

# ─── Cache & Queue ───────────────────────────────────────────
BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=1440

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@edulink.com
MAIL_PASSWORD=YOUR_EMAIL_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@edulink.com"
MAIL_FROM_NAME="EduLink"

# ─── Google OAuth ────────────────────────────────────────────
# Get credentials from: https://console.cloud.google.com/
# Create OAuth 2.0 Client ID (Web application)
# Add redirect: http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=264019535722-fg4ic8fo6b15uj6na9s5ijtcrgais7t4.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ─── Firebase (Push Notifications) ──────────────────────────
FIREBASE_CREDENTIALS=storage/app/firebase-credentials.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ─── File Storage ────────────────────────────────────────────
# Local storage (default) - change to s3 for production scale
FILESYSTEM_DISK=local
MAX_FILE_SIZE_MB=100

# ─── Real-time (Socket.io via Node.js) ───────────────────────
SOCKET_SERVER_URL=http://localhost:3001
SOCKET_SECRET=YOUR_SOCKET_SECRET_KEY

# ─── AI Providers (Free Tier APIs) ───────────────────────────
# 1. Google Gemini (1,500 requests/day FREE)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-1.5-flash

# 2. Groq (14,400 requests/day FREE - ultra fast)
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama3-8b-8192

# 3. Cohere (1,000 requests/day FREE)
COHERE_API_KEY=YOUR_COHERE_API_KEY
COHERE_MODEL=command-r

# 4. Mistral AI (1,000 requests/day FREE)
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY
MISTRAL_MODEL=mistral-7b-instruct

# 5. Together AI (1,000 credits FREE)
TOGETHER_API_KEY=YOUR_TOGETHER_API_KEY
TOGETHER_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# 6. HuggingFace (Unlimited - slower, always works as fallback)
HUGGINGFACE_API_KEY=YOUR_HUGGINGFACE_API_KEY
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# ─── Jitsi Video Meetings ────────────────────────────────────
JITSI_APP_ID=YOUR_JITSI_APP_ID
JITSI_APP_SECRET=YOUR_JITSI_APP_SECRET
JITSI_DOMAIN=meet.jit.si

# ─── Security ────────────────────────────────────────────────
JWT_SECRET=YOUR_VERY_LONG_RANDOM_JWT_SECRET_AT_LEAST_64_CHARS
SANCTUM_STATEFUL_DOMAINS=edulink.com,www.edulink.com,localhost:3000,127.0.0.1:3000
CORS_ALLOWED_ORIGINS=https://edulink.com,https://www.edulink.com,http://localhost:3000,http://127.0.0.1:3000

# ─── Rate Limiting ───────────────────────────────────────────
API_RATE_LIMIT_PER_MINUTE=120
AI_RATE_LIMIT_PER_HOUR=100
